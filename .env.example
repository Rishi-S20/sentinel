# ===========================================
# Sentinel - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

ALPHA_VANTAGE_API_KEY = "DYAT2TZ1IT8LOUS9"


# ----- Database -----
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_dev_password
POSTGRES_DB=sentinel
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel_dev_password@db:5432/sentinel
DATABASE_URL_SYNC=postgresql://sentinel:sentinel_dev_password@db:5432/sentinel

# ----- Redis -----
REDIS_URL=redis://redis:6379/0

# ----- Auth -----
SECRET_KEY=change-me-to-a-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ----- Google OAuth (optional for now) -----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----- AI / LLM -----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ----- Market Data APIs -----
ALPHA_VANTAGE_API_KEY=
COINgecko_API_KEY=

# ----- News APIs -----
NEWS_API_KEY=

# ----- Reddit API -----
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=sentinel-bot/0.1

# ----- Stripe (test keys) -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=

# ----- Email -----
SENDGRID_API_KEY=
FROM_EMAIL=briefings@sentinel.app

# ----- App Config -----
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173"]
